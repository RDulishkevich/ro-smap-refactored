# Пример env для Yandex Cloud Function (не коммитить реальные значения)

BUCKET=rosmap2026
PRIVATE_BUCKET=rosmap2026-private
STORAGE_ENDPOINT=https://storage.yandexcloud.net
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
JWT_SECRET=change-me-to-long-random-string
ADMIN_PASSWORD=change-me
ALLOWED_ORIGIN=https://polevka.art,https://www.polevka.art,https://rdulishkevich.github.io,http://localhost,http://127.0.0.1

# Yandex Translate (для UCS FXName: RU → EN)
YC_TRANSLATE_API_KEY=
YC_FOLDER_ID=

# Browser Maps JS key (HTTP Referer restricted). Served via action=publicConfig only.
YANDEX_MAPS_API_KEY=

# Transactional email (verification codes). Leave empty until mailbox is ready.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
# Staging only — return demoCode when SMTP is missing. Never enable on production.
ALLOW_DEMO_EMAIL_CODES=0
